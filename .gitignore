# ============================================================
#  桌宠项目 .gitignore — 上传 GitHub/Gitee 前的完整排除清单
# ============================================================

# ── 用户私人数据（绝不上传）──────────────────────────────────
geren/

# ── 开发者工具（仅本地使用，不随项目发布）───────────────────
tools/

# ── Python 缓存 / 构建产物 ─────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.spec

# ── Claude Code 本地配置 ───────────────────────────────────
.claude/

# ── IDE / 编辑器 ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── 操作系统 ───────────────────────────────────────────────
Thumbs.db
.DS_Store
desktop.ini

# ── 内部开发文档 ──────────────────────────────────────────
PRD.md
CLAUDE.md
docs/
